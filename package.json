    "jszip": "^3.10.1",
    "mammoth": "^1.6.0",
    "marked": "^12.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "pptxgenjs": "^3.12.0",
    "qrcode": "^1.5.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nwjs-builder-phoenix": "^1.15.0"
  }
}
