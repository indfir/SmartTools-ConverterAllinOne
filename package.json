{
  "name": "smarttools",
  "version": "1.0.0",
  "description": "SmartTools - Universal File Converter Desktop App",
  "main": "index.html",
  "window": {
    "title": "SmartTools - Universal File Converter",
    "icon": "icon.png",
    "width": 1400,
    "height": 900,
    "min_width": 1000,
    "min_height": 700,
    "position": "center",
